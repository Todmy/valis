# Teamind Web — Vercel Deployment Environment Variables
# T047: All required env vars for Vercel API route deployment.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth (required) ---
JWT_SECRET=your-jwt-secret

# --- Qdrant (required) ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# --- Stripe (required for billing routes) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# --- Resend (required for invite emails) ---
RESEND_API_KEY=re_...

# --- Anthropic (optional — required for /api/enrich) ---
ANTHROPIC_API_KEY=sk-ant-...
